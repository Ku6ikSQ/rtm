# PostgreSQL
DB_USERNAME=rtm_user
DB_PASSWORD=change_me_strong_password

# JWT — сгенерировать: openssl rand -base64 32
JWT_SECRET_KEY=change_me_generate_with_openssl

# CORS — публичный URL фронтенда (без слеша в конце)
# Несколько через запятую: http://domain.com,https://domain.com
ALLOWED_ORIGINS=http://YOUR_VPS_IP

# SeaweedFS S3
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=change_me_strong_secret
STORAGE_BUCKET=rtm
# Публичный URL SeaweedFS для presigned URL (открывается браузером)
STORAGE_PUBLIC_URL=http://YOUR_VPS_IP:8333
